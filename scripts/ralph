#!/usr/bin/env bash
set -euo pipefail

command_name="${RALPH_COMMAND_NAME:-$(basename "$0")}"

usage() {
  cat <<'EOF' | sed "s/__CMD__/${command_name}/g"
Run Ralph's sequential Codex prompt loop from any directory.

Usage:
  __CMD__ [mode] -n N --prompt VALUE
  __CMD__ [mode] "Your prompt"
  cat prompt.txt | __CMD__ [mode]
  __CMD__

Options:
  --backend BACKEND        Runner backend: codex or opencode (default: codex).
  --mode MODE              Execution mode / permissions profile for codex exec
                           (default: inherit).
                           Modes:
                             inherit         Keep existing codex defaults/profile.
                             default         Use the explicit Codex preset:
                                             current Codex model/reasoning
                                             + unrestricted
                                             execution.
                             read-only       Pass --sandbox read-only.
                             workspace-write Pass --sandbox workspace-write.
                             full-auto       Pass --full-auto.
                             danger          Pass --dangerously-bypass-approvals-and-sandbox.
  --interactive            Open the small setup menu instead of requiring all
                           options up front. If you launch `__CMD__`
                           without a prompt in a TTY, the menu opens
                           automatically.
  --prompt VALUE           Prompt text to send each run. If VALUE is an existing
                           file path, the file contents are used as the prompt.
  --prompt-file PATH       Read prompt text from file.
  -n, --count N            Number of runs (default: 5).
  --delay SECONDS          Sleep between runs (default: 0).
  --model MODEL            Pass model to the selected backend.
  --profile PROFILE        Pass profile to codex exec (-p).
  --agent AGENT            Pass agent to opencode run (--agent).
  --cd DIR                 Override the default working directory.
                           Default: the directory where you launched __CMD__.
  --out-dir DIR            Override the default output directory.
                           Default: <effective-workdir>/.ralph/<timestamp-pid>/.
  --continue-on-error      Continue remaining runs if one fails.
  --dry-run                Print commands without executing.
  --color                  Force ANSI color output (even when not a TTY).
  --no-color               Disable ANSI color output.
  -h, --help               Show this help.

Notes:
  - `--backend codex` runs `codex exec`; `--backend opencode` runs
    `opencode run`.
  - `default` keeps the same model/reasoning that plain `codex` would use,
    while still forcing `--dangerously-bypass-approvals-and-sandbox`.
  - With `--backend opencode`, `ralph` inherits the current opencode model
    and agent defaults unless you pass `--model` or `--agent`.
  - `inherit` keeps the current Codex config/profile instead.
  - If no prompt is supplied, non-interactive runs use `RALPH.md` from the
    effective working directory when that file exists.
  - Running `__CMD__` with no prompt in an interactive terminal opens a
    small setup menu for backend, mode, model, prompt selection, run count,
    and a few execution toggles, while inferring the target directory from
    where you launched the command.
  - On real TTYs, compact selectors use ←/→ (or h/l) and Enter.
  - The TTY model picker stays intentionally small: use plain Codex
    defaults, or enter a custom model override manually.
  - By default, Codex runs in the directory where you launched `__CMD__`.
  - If you choose a different working directory via `--cd`, relative
    prompt-file lookup and default `.ralph/<timestamp-pid>/` outputs
    follow that target directory instead.
  - The wrapper always passes `--skip-git-repo-check`, so it can run from
    non-repo directories too.
  - Any arguments after -- are forwarded directly to codex exec.
  - Color is enabled automatically on TTYs. Set `NO_COLOR=1` to disable,
    or `RALPH_COLOR=always|never|auto` to control it.

Examples:
  __CMD__ default -n 10 --prompt prompt.md
  __CMD__ --backend opencode --agent build -n 3 --prompt prompt.md
  __CMD__ full-auto -n 5 --prompt "review this repo and list TODOs"
  __CMD__ read-only --prompt prompt.txt -- --json
  __CMD__
EOF
}

to_lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

resolve_script_path() {
  local source_path="$1"
  local source_dir=""
  local target_path=""

  while [[ -L "$source_path" ]]; do
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    target_path="$(readlink "$source_path")"
    if [[ "$target_path" == /* ]]; then
      source_path="$target_path"
    else
      source_path="${source_dir}/${target_path}"
    fi
  done

  source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
  printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

array_length() {
  local array_name="$1"

  eval "printf '%s' \"\${#${array_name}[@]}\""
}

array_get() {
  local array_name="$1"
  local index="$2"

  eval "printf '%s' \"\${${array_name}[$index]-}\""
}

array_contains() {
  local array_name="$1"
  local expected_value="$2"
  local count=0
  local index=0
  local current_value=""

  count="$(array_length "$array_name")"
  for ((index = 0; index < count; index++)); do
    current_value="$(array_get "$array_name" "$index")"
    if [[ "$current_value" == "$expected_value" ]]; then
      return 0
    fi
  done

  return 1
}

script_path="$(resolve_script_path "${BASH_SOURCE[0]}")"
repo_root="$(cd "$(dirname "$script_path")/.." && pwd)"
repeat_script="${repo_root}/scripts/repeat_codex_prompt.sh"
arrow_key_read_timeout="0.1"

if ((BASH_VERSINFO[0] < 4)); then
  arrow_key_read_timeout="1"
fi

if [[ ! -x "$repeat_script" ]]; then
  echo "repeat runner not found or not executable: $repeat_script" >&2
  exit 1
fi

launch_dir="$(pwd)"
session_stamp="$(date -u +%Y%m%dT%H%M%SZ)-pid$$"

mode="inherit"
backend="codex"
backend_set=0
mode_set=0
interactive=0
prompt_kind=""
prompt_value=""
count=5
delay=0
model=""
profile=""
agent=""
workdir="$launch_dir"
out_dir=""
out_dir_explicit=0
continue_on_error=0
dry_run=0
extra_args=()
default_prompt_filename="RALPH.md"
color_mode="${RALPH_COLOR:-auto}"
color_mode_set=0
use_color=0
C_RESET=""
C_BOLD=""
C_DIM=""
C_CYAN=""
C_GREEN=""
C_YELLOW=""
C_RED=""
C_ORANGE=""
C_GRAY=""

require_value() {
  local flag="$1"

  [[ $# -ge 2 ]] || {
    echo "missing value for ${flag}" >&2
    exit 2
  }
}

is_mode_name() {
  case "$1" in
    inherit|default|current|read-only|workspace-write|full-auto|danger|danger-full-access)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_backend_name() {
  case "$1" in
    codex|opencode)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

supports_truecolor() {
  case "${COLORTERM:-}" in
    *truecolor*|*24bit*)
      return 0
      ;;
  esac

  case "${TERM:-}" in
    *-direct*)
      return 0
      ;;
  esac

  return 1
}

ansi_fg_rgb() {
  printf '\033[38;2;%s;%s;%sm' "$1" "$2" "$3"
}

ansi_fg_256() {
  printf '\033[38;5;%sm' "$1"
}

configure_colors() {
  local normalized=""

  if [[ -n "${NO_COLOR+x}" ]]; then
    use_color=0
  else
    normalized="$(to_lower "$color_mode")"
    case "$normalized" in
      auto|"")
        if [[ -t 1 && "${TERM:-}" != "dumb" ]]; then
          use_color=1
        else
          use_color=0
        fi
        ;;
      always|force|yes|true|1)
        use_color=1
        ;;
      never|no|false|0)
        use_color=0
        ;;
      *)
        echo "unsupported color mode: ${color_mode}" >&2
        echo "supported: auto, always, never" >&2
        exit 2
        ;;
    esac
  fi

  if ((use_color)); then
    C_RESET=$'\033[0m'
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    if supports_truecolor; then
      # Gruvbox-ish palette (truecolor).
      C_ORANGE="$(ansi_fg_rgb 254 128 25)"  # #fe8019
      C_CYAN="$(ansi_fg_rgb 131 165 152)"   # #83a598 (blue)
      C_GREEN="$(ansi_fg_rgb 184 187 38)"   # #b8bb26
      C_YELLOW="$(ansi_fg_rgb 250 189 47)"  # #fabd2f
      C_RED="$(ansi_fg_rgb 251 73 52)"      # #fb4934
      C_GRAY="$(ansi_fg_rgb 146 131 116)"   # #928374
    else
      # Gruvbox-ish palette (256-color fallback).
      C_ORANGE="$(ansi_fg_256 208)"
      C_CYAN="$(ansi_fg_256 109)"
      C_GREEN="$(ansi_fg_256 142)"
      C_YELLOW="$(ansi_fg_256 214)"
      C_RED="$(ansi_fg_256 167)"
      C_GRAY="$(ansi_fg_256 243)"
    fi
  else
    C_RESET=""
    C_BOLD=""
    C_DIM=""
    C_CYAN=""
    C_GREEN=""
    C_YELLOW=""
    C_RED=""
    C_ORANGE=""
    C_GRAY=""
  fi
}

auto_select_backend() {
  if ((backend_set)); then
    return
  fi

  if [[ "$backend" == "codex" ]] && ! command_exists codex && command_exists opencode; then
    backend="opencode"
  fi
}

default_session_dir_for_dir() {
  printf '%s/.ralph/%s' "$1" "$session_stamp"
}

default_prompt_for_dir() {
  local base_dir="$1"
  local resolved=""

  if resolved="$(resolve_existing_file_path "$default_prompt_filename" "$base_dir")"; then
    printf '%s' "$resolved"
    return 0
  fi

  return 1
}

resolve_existing_file_path() {
  local value="$1"
  local base_dir="${2:-}"

  if [[ -f "$value" ]]; then
    printf '%s' "$value"
    return 0
  fi

  if [[ -n "$base_dir" && "$value" != /* && -f "$base_dir/$value" ]]; then
    printf '%s' "$base_dir/$value"
    return 0
  fi

  return 1
}

normalize_prompt_for_workdir() {
  local base_dir="$1"
  local resolved=""

  if [[ -z "$prompt_kind" || -z "$prompt_value" ]]; then
    return
  fi

  case "$prompt_kind" in
    file)
      if resolved="$(resolve_existing_file_path "$prompt_value" "$base_dir")"; then
        prompt_value="$resolved"
      fi
      ;;
    text)
      if resolved="$(resolve_existing_file_path "$prompt_value" "$base_dir")"; then
        prompt_kind="file"
        prompt_value="$resolved"
      fi
      ;;
  esac
}

apply_default_prompt_for_workdir() {
  local base_dir="$1"
  local resolved=""

  if [[ -n "$prompt_kind" ]]; then
    return
  fi

  if resolved="$(default_prompt_for_dir "$base_dir")"; then
    prompt_kind="file"
    prompt_value="$resolved"
  fi
}

set_prompt_from_value() {
  local value="$1"

  if [[ -f "$value" ]]; then
    prompt_kind="file"
  else
    prompt_kind="text"
  fi
  prompt_value="$value"
}

prompt_with_default() {
  local message="$1"
  local default_value="$2"
  local __resultvar="$3"
  local answer=""

  # The arrow-menu path uses single-key reads. Restoring a sane TTY here keeps
  # line prompts visible and editable on older macOS Bash sessions.
  if [[ -t 0 ]]; then
    stty sane <&0 >/dev/null 2>&1 || true
  fi

  if [[ -n "$default_value" ]]; then
    read -r -p "${message} [${default_value}]: " answer
    answer="${answer:-$default_value}"
  else
    read -r -p "${message}: " answer
  fi

  printf -v "$__resultvar" '%s' "$answer"
}

ask_yes_no() {
  local message="$1"
  local default_answer="$2"
  local __resultvar="$3"
  local answer=""
  local normalized=""
  local prompt_suffix="[y/N]"
  local yes_no_values=("no" "yes")
  local yes_no_labels=("no" "yes")
  local yes_no_descriptions=("disable" "enable")

  if [[ "$default_answer" == "yes" ]]; then
    prompt_suffix="[Y/n]"
  fi

  if [[ -t 0 && -t 1 ]]; then
    choose_with_arrows "$message" normalized "$default_answer" yes_no_values yes_no_labels yes_no_descriptions
    printf -v "$__resultvar" '%s' "$normalized"
    return
  fi

  while true; do
    read -r -p "${message} ${prompt_suffix}: " answer
    normalized="${answer:-$default_answer}"
    case "$(to_lower "$normalized")" in
      y|yes)
        printf -v "$__resultvar" '%s' "yes"
        return
        ;;
      n|no)
        printf -v "$__resultvar" '%s' "no"
        return
        ;;
    esac
    echo "enter yes or no" >&2
  done
}

ask_launch_now() {
  local default_answer="$1"
  local __resultvar="$2"
  local normalized=""
  local launch_values=("no" "yes")
  local launch_labels=("no" "yes")
  local launch_descriptions=("abort" "launch")

  if [[ -t 0 && -t 1 ]]; then
    choose_with_arrows "Launch now" normalized "$default_answer" launch_values launch_labels launch_descriptions
    printf -v "$__resultvar" '%s' "$normalized"
    return
  fi

  ask_yes_no "Launch now" "$default_answer" "$__resultvar"
}

choose_with_arrows() {
  local title="$1"
  local __resultvar="$2"
  local default_value="$3"
  local values_name="$4"
  local labels_name="$5"
  local descriptions_name="$6"
  local key=""
  local rest=""
  local index=0
  local candidate=""
  local count=0
  local current_label=""
  local current_description=""
  local candidate_value=""

  count="$(array_length "$values_name")"
  if [[ "$count" -eq 0 ]]; then
    echo "internal error: choose_with_arrows requires at least one option" >&2
    return 1
  fi

  for ((candidate = 0; candidate < count; candidate++)); do
    candidate_value="$(array_get "$values_name" "$candidate")"
    if [[ "$candidate_value" == "$default_value" ]]; then
      index="$candidate"
      break
    fi
  done

  while true; do
    current_label="$(array_get "$labels_name" "$index")"
    current_description="$(array_get "$descriptions_name" "$index")"

    printf '\r\033[2K%s%s: < %s >%s' "$C_CYAN" "$title" "$current_label" "$C_RESET"
    if [[ -n "$current_description" ]]; then
      printf '  %s%s%s' "$C_GRAY" "$current_description" "$C_RESET"
    fi
    printf '  %s[←/→, Enter]%s' "$C_GRAY" "$C_RESET"

    IFS= read -rsn1 key || true
    case "$key" in
      "")
        break
        ;;
      $'\n')
        break
        ;;
      $'\r')
        break
        ;;
      h|H)
        index=$(( (index - 1 + count) % count ))
        ;;
      l|L)
        index=$(( (index + 1) % count ))
        ;;
      $'\x1b')
        IFS= read -rsn2 -t "$arrow_key_read_timeout" rest || true
        case "$rest" in
          "[D") index=$(( (index - 1 + count) % count )) ;;
          "[C") index=$(( (index + 1) % count )) ;;
        esac
        ;;
    esac
  done

  printf '\r\033[2K%s%s: %s%s\n' "$C_CYAN" "$title" "$(array_get "$labels_name" "$index")" "$C_RESET"
  printf -v "$__resultvar" '%s' "$(array_get "$values_name" "$index")"
}

choose_mode_interactive() {
  local selection=""
  local default_selection="1"
  local mode_values=("inherit" "default" "read-only" "workspace-write" "full-auto" "danger")
  local mode_labels=("inherit" "default" "read-only" "workspace-write" "full-auto" "danger")
  local mode_descriptions=(
    "keep current Codex defaults/profile"
    "plain codex model/reasoning + unrestricted execution"
    "sandbox read-only"
    "sandbox workspace-write"
    "full-auto convenience mode"
    "dangerously bypass approvals + sandbox"
  )

  case "$mode" in
    default) default_selection="2" ;;
    read-only) default_selection="3" ;;
    workspace-write) default_selection="4" ;;
    full-auto) default_selection="5" ;;
    danger|danger-full-access) default_selection="6" ;;
  esac

  if [[ -t 0 && -t 1 ]]; then
    choose_with_arrows "Mode" mode "$mode" mode_values mode_labels mode_descriptions
    return
  fi

  cat <<'EOF'

Execution mode / permissions:
  1) inherit         Keep current Codex defaults/profile
  2) default         plain codex model/reasoning + unrestricted execution
  3) read-only       --sandbox read-only
  4) workspace-write --sandbox workspace-write
  5) full-auto       --full-auto
  6) danger          --dangerously-bypass-approvals-and-sandbox
EOF

  while true; do
    read -r -p "Choose mode [${default_selection}]: " selection
    selection="${selection:-$default_selection}"
    case "$(to_lower "$selection")" in
      1|inherit|current)
        mode="inherit"
        return
        ;;
      2|default)
        mode="default"
        return
        ;;
      3|read-only)
        mode="read-only"
        return
        ;;
      4|workspace-write)
        mode="workspace-write"
        return
        ;;
      5|full-auto)
        mode="full-auto"
        return
        ;;
      6|danger|danger-full-access)
        mode="danger"
        return
        ;;
    esac
    echo "unsupported choice: ${selection}" >&2
  done
}

choose_backend_interactive() {
  local selection=""
  local default_selection="1"
  local codex_description="codex exec prompt loop"
  local opencode_description="opencode run prompt loop"
  local backend_values=("codex" "opencode")
  local backend_labels=("codex" "opencode")
  local backend_descriptions=()

  if ! command_exists codex; then
    codex_description="codex exec (not found on PATH)"
  fi

  if ! command_exists opencode; then
    opencode_description="opencode run (not found on PATH)"
  fi

  backend_descriptions=("$codex_description" "$opencode_description")

  case "$backend" in
    opencode) default_selection="2" ;;
  esac

  if [[ -t 0 && -t 1 ]]; then
    choose_with_arrows "Backend" backend "$backend" backend_values backend_labels backend_descriptions
    return
  fi

  cat <<EOF

Backend:
  1) codex    ${codex_description}
  2) opencode ${opencode_description}
EOF

  while true; do
    read -r -p "Choose backend [${default_selection}]: " selection
    selection="${selection:-$default_selection}"
    case "$(to_lower "$selection")" in
      1|codex)
        backend="codex"
        return
        ;;
      2|opencode)
        backend="opencode"
        return
        ;;
    esac
    echo "unsupported choice: ${selection}" >&2
  done
}

choose_model_interactive() {
  local current_value="$1"
  local __resultvar="$2"
  local selection=""
  local custom_default="$current_value"
  local model_values=(
    "__MODE_DEFAULT__"
    "__CUSTOM__"
  )
  local model_labels=(
    "backend default"
    "custom"
  )
  local model_descriptions=(
    "use the current backend default model"
    "type any model id manually"
  )

  if [[ -z "$current_value" ]]; then
    selection="__MODE_DEFAULT__"
  else
    selection="$current_value"
    if ! array_contains model_values "$selection"; then
      selection="__CUSTOM__"
    fi
  fi

  if [[ -t 0 && -t 1 ]]; then
    choose_with_arrows "Model" selection "$selection" model_values model_labels model_descriptions
  else
    prompt_with_default "Model override (blank keeps current backend defaults)" "$current_value" current_value
    printf -v "$__resultvar" '%s' "$current_value"
    return
  fi

  case "$selection" in
    "__MODE_DEFAULT__")
      current_value=""
      ;;
    "__CUSTOM__")
      prompt_with_default "Custom model id" "$custom_default" current_value
      ;;
    *)
      current_value="$selection"
      ;;
  esac

  printf -v "$__resultvar" '%s' "$current_value"
}

choose_count_interactive() {
  local current_value="$1"
  local __resultvar="$2"
  local selection="$current_value"
  local show_selector=1
  local count_values=("1" "2" "3" "5" "10" "20" "__CUSTOM__")
  local count_labels=("1" "2" "3" "5" "10" "20" "custom")
  local count_descriptions=(
    "single run"
    "two runs"
    "default"
    "quick batch"
    "larger batch"
    "longer sweep"
    "type any positive integer"
  )

  if ! array_contains count_values "$selection"; then
    selection="__CUSTOM__"
    show_selector=0
  fi

  if [[ -t 0 && -t 1 && "$show_selector" -eq 1 ]]; then
    choose_with_arrows "Run count" selection "$selection" count_values count_labels count_descriptions
    if [[ "$selection" == "__CUSTOM__" ]]; then
      while true; do
        prompt_with_default "How many runs" "$current_value" current_value
        if [[ "$current_value" =~ ^[1-9][0-9]*$ ]]; then
          break
        fi
        echo "run count must be an integer >= 1" >&2
      done
    else
      current_value="$selection"
    fi
  else
    while true; do
      prompt_with_default "How many runs" "$current_value" current_value
      if [[ "$current_value" =~ ^[1-9][0-9]*$ ]]; then
        break
      fi
      echo "run count must be an integer >= 1" >&2
    done
  fi

  printf -v "$__resultvar" '%s' "$current_value"
}

choose_delay_interactive() {
  local current_value="$1"
  local __resultvar="$2"
  local selection="$current_value"
  local show_selector=1
  local delay_values=("0" "1" "2" "5" "__CUSTOM__")
  local delay_labels=("0" "1" "2" "5" "custom")
  local delay_descriptions=(
    "no delay"
    "1 second"
    "2 seconds"
    "5 seconds"
    "press Enter to type a number"
  )

  if ! array_contains delay_values "$selection"; then
    selection="__CUSTOM__"
    show_selector=0
  fi

  if [[ -t 0 && -t 1 && "$show_selector" -eq 1 ]]; then
    choose_with_arrows "Delay" selection "$selection" delay_values delay_labels delay_descriptions
    if [[ "$selection" == "__CUSTOM__" ]]; then
      while true; do
        prompt_with_default "Delay between runs in seconds" "$current_value" current_value
        if [[ "$current_value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
          break
        fi
        echo "delay must be a non-negative number" >&2
      done
    else
      current_value="$selection"
    fi
  else
    while true; do
      prompt_with_default "Delay between runs in seconds" "$current_value" current_value
      if [[ "$current_value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
        break
      fi
      echo "delay must be a non-negative number" >&2
    done
  fi

  printf -v "$__resultvar" '%s' "$current_value"
}

choose_prompt_interactive() {
  local base_dir="$1"
  local selection=""
  local default_selection="1"
  local prompt_file_default=""
  local prompt_text_default=""
  local candidate_path=""
  local prompt_values=()
  local prompt_labels=()
  local prompt_descriptions=()
  local prompt_files_added=0
  local max_prompt_files=25
  local file_candidate=""
  local file_label=""
  local file_value=""
  local custom_choice="__CUSTOM_FILE_PATH__"
  local text_choice="__PROMPT_TEXT__"

  if [[ "$prompt_kind" == "text" ]]; then
    prompt_text_default="$prompt_value"
  else
    if [[ -n "$prompt_value" ]]; then
      prompt_file_default="$prompt_value"
    elif candidate_path="$(default_prompt_for_dir "$base_dir")"; then
      prompt_file_default="$candidate_path"
    fi
  fi

  if [[ -t 0 && -t 1 ]]; then
    if [[ -f "${base_dir}/${default_prompt_filename}" ]]; then
      file_label="$default_prompt_filename"
      if [[ "$base_dir" == "$launch_dir" ]]; then
        file_value="$default_prompt_filename"
      else
        file_value="${base_dir}/${default_prompt_filename}"
      fi
      prompt_values+=("$file_value")
      prompt_labels+=("$file_label")
      prompt_descriptions+=("")
      prompt_files_added=$((prompt_files_added + 1))
    fi

    for file_candidate in "${base_dir}"/*; do
      ((prompt_files_added < max_prompt_files)) || break
      [[ -f "$file_candidate" ]] || continue

      file_label="$(basename "$file_candidate")"
      [[ "$file_label" == "$default_prompt_filename" ]] && continue

      if [[ "$base_dir" == "$launch_dir" ]]; then
        file_value="$file_label"
      else
        file_value="$file_candidate"
      fi

      prompt_values+=("$file_value")
      prompt_labels+=("$file_label")
      prompt_descriptions+=("")
      prompt_files_added=$((prompt_files_added + 1))
    done

    prompt_values+=("$custom_choice" "$text_choice")
    prompt_labels+=("custom file path" "text")
    prompt_descriptions+=("enter a path to a prompt file" "type a single-line prompt")

    if [[ "$prompt_kind" == "text" ]]; then
      selection="$text_choice"
    elif [[ -n "$prompt_file_default" ]]; then
      selection="$prompt_file_default"
    else
      selection="$custom_choice"
    fi

    echo
    choose_with_arrows "Prompt" selection "$selection" prompt_values prompt_labels prompt_descriptions
  else
    if [[ -f "${base_dir}/${default_prompt_filename}" ]]; then
      default_selection="1"
    else
      default_selection="2"
    fi
    if [[ "$prompt_kind" == "text" ]]; then
      default_selection="3"
    fi

    echo
    echo "Prompt:"
    echo "  1) default file (${default_prompt_filename})"
    echo "  2) file path"
    echo "  3) text"

    read -r -p "Choose prompt [${default_selection}]: " selection
    selection="${selection:-$default_selection}"
    case "$(to_lower "$selection")" in
      1|default)
        if [[ -n "$prompt_file_default" ]]; then
          prompt_kind="file"
          prompt_value="$prompt_file_default"
          return
        fi
        selection="$custom_choice"
        ;;
      2|file)
        selection="$custom_choice"
        ;;
      3|text)
        selection="$text_choice"
        ;;
      *)
        echo "unsupported choice: ${selection}" >&2
        return 1
        ;;
    esac
  fi

  case "$selection" in
    "$custom_choice")
      while true; do
        prompt_with_default "Prompt file path" "$prompt_file_default" prompt_file_default
        candidate_path="$prompt_file_default"
        if [[ -z "$candidate_path" ]]; then
          echo "prompt file path is required" >&2
        elif prompt_file_default="$(resolve_existing_file_path "$candidate_path" "$base_dir")"; then
          prompt_kind="file"
          prompt_value="$prompt_file_default"
          return
        else
          echo "prompt file not found: $candidate_path" >&2
        fi
      done
      ;;
    "$text_choice")
      while true; do
        prompt_with_default "Prompt text (single line)" "$prompt_text_default" prompt_text_default
        if [[ -z "$prompt_text_default" ]]; then
          echo "prompt text is required" >&2
        else
          prompt_kind="text"
          prompt_value="$prompt_text_default"
          return
        fi
      done
      ;;
    *)
      prompt_kind="file"
      prompt_value="$selection"
      return
      ;;
  esac
}

configure_interactive() {
  local run_count="$count"
  local delay_value="$delay"
  local model_value="$model"
  local profile_value="$profile"
  local agent_value="$agent"
  local workdir_value="$workdir"
  local out_dir_value="$out_dir"
  local continue_value="no"
  local dry_run_value="no"
  local should_launch="yes"
  local rule="---------------------------------------------------------------------"

  if ((continue_on_error)); then
    continue_value="yes"
  fi
  if ((dry_run)); then
    dry_run_value="yes"
  fi

  echo "${C_BOLD}${C_ORANGE}${command_name} interactive setup${C_RESET}"
  echo "${C_GRAY}${rule}${C_RESET}"
  echo "${C_BOLD}${C_YELLOW}Context:${C_RESET}"
  echo "  launch_dir=${launch_dir}"
  echo "  workdir=${workdir_value}"
  echo "  out_dir=${out_dir_value}"
  echo "${C_GRAY}${rule}${C_RESET}"
  echo

  choose_backend_interactive

  if [[ "$backend" == "codex" ]]; then
    choose_mode_interactive
  else
    mode="inherit"
  fi
  choose_model_interactive "$model_value" model_value
  if [[ "$backend" == "codex" ]]; then
    prompt_with_default "Profile override (blank keeps current profile)" "$profile_value" profile_value
    agent_value=""
  else
    prompt_with_default "Agent override (blank keeps current opencode agent)" "$agent_value" agent_value
    profile_value=""
  fi
  choose_count_interactive "$run_count" run_count
  choose_delay_interactive "$delay_value" delay_value

  if ((out_dir_explicit == 0)); then
    out_dir_value="$(default_session_dir_for_dir "$workdir_value")"
  fi

  choose_prompt_interactive "$workdir_value"

  ask_yes_no "Continue on error" "$continue_value" continue_value
  ask_yes_no "Dry run" "$dry_run_value" dry_run_value

  echo
  echo "${C_GRAY}${rule}${C_RESET}"
  echo "${C_BOLD}${C_YELLOW}Summary:${C_RESET}"
  echo "  backend=${backend}"
  echo "  mode=${mode}"
  echo "  model=${model_value:-<current ${backend} default>}"
  if [[ "$backend" == "codex" ]]; then
    echo "  profile=${profile_value:-<inherit>}"
  else
    echo "  agent=${agent_value:-<current opencode default>}"
  fi
  echo "  count=${run_count}"
  echo "  delay=${delay_value}"
  echo "  prompt_${prompt_kind}=${prompt_value}"
  echo "  workdir=${workdir_value}"
  echo "  out_dir=${out_dir_value}"
  echo "  continue_on_error=${continue_value}"
  echo "  dry_run=${dry_run_value}"
  echo "${C_GRAY}${rule}${C_RESET}"
  echo

  ask_launch_now "$should_launch" should_launch
  if [[ "$should_launch" != "yes" ]]; then
    echo "aborted" >&2
    exit 0
  fi

  count="$run_count"
  delay="$delay_value"
  model="$model_value"
  profile="$profile_value"
  agent="$agent_value"
  workdir="$workdir_value"
  out_dir="$out_dir_value"
  continue_on_error=0
  dry_run=0

  if [[ "$continue_value" == "yes" ]]; then
    continue_on_error=1
  fi
  if [[ "$dry_run_value" == "yes" ]]; then
    dry_run=1
  fi
}

positional_prompt=""

while (($# > 0)); do
  case "$1" in
    --backend=*)
      backend="${1#*=}"
      backend_set=1
      shift
      ;;
    --backend)
      require_value "$1" "$@"
      backend="$2"
      backend_set=1
      shift 2
      ;;
    --mode=*)
      ((mode_set == 0)) || {
        echo "mode specified more than once" >&2
        exit 2
      }
      mode="${1#*=}"
      mode_set=1
      shift
      ;;
    --mode)
      require_value "$1" "$@"
      ((mode_set == 0)) || {
        echo "mode specified more than once" >&2
        exit 2
      }
      mode="$2"
      mode_set=1
      shift 2
      ;;
    --interactive)
      interactive=1
      shift
      ;;
    --prompt=*)
      [[ -z "$prompt_kind" ]] || {
        echo "prompt specified more than once" >&2
        exit 2
      }
      [[ -z "$positional_prompt" ]] || {
        echo "use either positional prompt, --prompt, or --prompt-file" >&2
        exit 2
      }
      set_prompt_from_value "${1#*=}"
      shift
      ;;
    --prompt)
      require_value "$1" "$@"
      [[ -z "$prompt_kind" ]] || {
        echo "prompt specified more than once" >&2
        exit 2
      }
      [[ -z "$positional_prompt" ]] || {
        echo "use either positional prompt, --prompt, or --prompt-file" >&2
        exit 2
      }
      set_prompt_from_value "$2"
      shift 2
      ;;
    --prompt-file=*)
      [[ -z "$prompt_kind" ]] || {
        echo "prompt specified more than once" >&2
        exit 2
      }
      [[ -z "$positional_prompt" ]] || {
        echo "use either positional prompt, --prompt, or --prompt-file" >&2
        exit 2
      }
      prompt_kind="file"
      prompt_value="${1#*=}"
      shift
      ;;
    --prompt-file)
      require_value "$1" "$@"
      [[ -z "$prompt_kind" ]] || {
        echo "prompt specified more than once" >&2
        exit 2
      }
      [[ -z "$positional_prompt" ]] || {
        echo "use either positional prompt, --prompt, or --prompt-file" >&2
        exit 2
      }
      prompt_kind="file"
      prompt_value="$2"
      shift 2
      ;;
    --count=*)
      count="${1#*=}"
      shift
      ;;
    -n|--count)
      require_value "$1" "$@"
      count="$2"
      shift 2
      ;;
    --delay=*)
      delay="${1#*=}"
      shift
      ;;
    --agent=*)
      agent="${1#*=}"
      shift
      ;;
    --cd=*)
      workdir="${1#*=}"
      if ((out_dir_explicit == 0)); then
        out_dir="$(default_session_dir_for_dir "$workdir")"
      fi
      shift
      ;;
    --out-dir=*)
      out_dir="${1#*=}"
      out_dir_explicit=1
      shift
      ;;
    --delay|--model|--profile|--agent|--cd|--out-dir)
      require_value "$1" "$@"
      case "$1" in
        --delay) delay="$2" ;;
        --model) model="$2" ;;
        --profile) profile="$2" ;;
        --agent) agent="$2" ;;
        --cd)
          workdir="$2"
          if ((out_dir_explicit == 0)); then
            out_dir="$(default_session_dir_for_dir "$workdir")"
          fi
          ;;
        --out-dir)
          out_dir="$2"
          out_dir_explicit=1
          ;;
      esac
      shift 2
      ;;
    --continue-on-error)
      continue_on_error=1
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --color)
      ((color_mode_set == 0)) || {
        echo "color option specified more than once" >&2
        exit 2
      }
      color_mode="always"
      color_mode_set=1
      shift
      ;;
    --no-color)
      ((color_mode_set == 0)) || {
        echo "color option specified more than once" >&2
        exit 2
      }
      color_mode="never"
      color_mode_set=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      extra_args=("$@")
      break
      ;;
    -*)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$positional_prompt" ]] && is_mode_name "$1"; then
        if ((mode_set == 0)); then
          mode="$1"
          mode_set=1
        else
          echo "mode specified more than once" >&2
          exit 2
        fi
      elif [[ -n "$positional_prompt" ]]; then
        echo "unexpected extra positional argument: $1" >&2
        usage >&2
        exit 2
      elif [[ -n "$prompt_kind" ]]; then
        echo "use either positional prompt, --prompt, or --prompt-file" >&2
        exit 2
      else
        positional_prompt="$1"
      fi
      shift
      ;;
  esac
done

if [[ -n "$positional_prompt" ]]; then
  set_prompt_from_value "$positional_prompt"
fi

if [[ -z "$out_dir" ]]; then
  out_dir="$(default_session_dir_for_dir "$workdir")"
fi

if ((interactive == 0)) && [[ -z "$prompt_kind" ]] && [[ -t 0 ]] && [[ -t 1 ]]; then
  interactive=1
fi

configure_colors
export RALPH_COLOR="$color_mode"

if ((interactive)); then
  configure_interactive
fi

apply_default_prompt_for_workdir "$workdir"
normalize_prompt_for_workdir "$workdir"

if ! [[ "$count" =~ ^[1-9][0-9]*$ ]]; then
  echo "--count must be an integer >= 1" >&2
  exit 2
fi

auto_select_backend

if ! is_backend_name "$backend"; then
  echo "unsupported backend: $backend" >&2
  echo "supported backends: codex, opencode" >&2
  exit 2
fi

if [[ "$backend" == "codex" && -n "$agent" ]]; then
  echo "--agent is only supported with --backend opencode" >&2
  exit 2
fi

if [[ "$backend" == "opencode" && -n "$profile" ]]; then
  echo "--profile is only supported with --backend codex" >&2
  exit 2
fi

mode_args=()
if [[ "$backend" == "codex" ]]; then
  case "$mode" in
    inherit|current)
      ;;
    default)
      mode_args=(--dangerously-bypass-approvals-and-sandbox)
      ;;
    read-only)
      mode_args=(--sandbox read-only)
      ;;
    workspace-write)
      mode_args=(--sandbox workspace-write)
      ;;
    full-auto)
      mode_args=(--full-auto)
      ;;
    danger|danger-full-access)
      mode_args=(--dangerously-bypass-approvals-and-sandbox)
      ;;
    *)
      echo "unsupported mode: $mode" >&2
      echo "supported modes: inherit, default, read-only, workspace-write, full-auto, danger" >&2
      exit 2
      ;;
  esac
else
  case "$mode" in
    inherit|current|default)
      mode="inherit"
      ;;
    *)
      echo "--backend opencode only supports inherit/current/default mode semantics" >&2
      exit 2
      ;;
  esac
fi

forward_args=(--backend "$backend" --count "$count" --delay "$delay" --cd "$workdir" --out-dir "$out_dir")

if [[ -n "$model" ]]; then
  forward_args+=(--model "$model")
fi

if [[ -n "$profile" ]]; then
  forward_args+=(--profile "$profile")
fi

if [[ -n "$agent" ]]; then
  forward_args+=(--agent "$agent")
fi

if [[ "$prompt_kind" == "file" ]]; then
  forward_args+=(--prompt-file "$prompt_value")
elif [[ "$prompt_kind" == "text" ]]; then
  forward_args+=(--prompt "$prompt_value")
fi

if ((continue_on_error)); then
  forward_args+=(--continue-on-error)
fi

if ((dry_run)); then
  forward_args+=(--dry-run)
fi

common_exec_args=()
if [[ "$backend" == "codex" ]]; then
  common_exec_args=(--skip-git-repo-check)
fi
cmd=("$repeat_script" "${forward_args[@]}")

if ((${#common_exec_args[@]} > 0 || ${#mode_args[@]} > 0 || ${#extra_args[@]} > 0)); then
  cmd+=(-- "${common_exec_args[@]}" "${mode_args[@]}" "${extra_args[@]}")
fi

exec "${cmd[@]}"
